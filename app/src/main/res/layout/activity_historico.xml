<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarHistorico"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="24dp"
        android:background="@color/coral_primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"

        app:title="Histórico"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarHistorico"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <ListView
            android:id="@+id/listViewHistorico"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:dividerHeight="8dp" />

        <LinearLayout
            android:id="@+id/layoutHistoricoVazio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_menu_recent_history"
                android:contentDescription="Histórico vazio" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Nenhuma sessão registrada"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:id="@+id/tvVazioHistorico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Conclua uma sessão para ver aqui."
                android:textSize="16sp"
                android:textColor="@color/text_muted" />

        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_menu_flutuante"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnNavInicio"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_inicio"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnNavHistorico"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_item_selecionado"
            android:src="@drawable/ic_nav_historico"
            app:tint="@color/coral_primary" />

        <ImageButton
            android:id="@+id/btnNavRelatorio"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_relatorio"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnNavConfig"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_config"
            app:tint="@color/text_muted" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>