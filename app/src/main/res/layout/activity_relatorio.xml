<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="32dp"
    android:layout_marginBottom="32dp"
    android:background="@color/bg_white">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarRelatorio"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/coral_primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"

        app:title="Relatório"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarRelatorio"
        app:layout_constraintBottom_toTopOf="@id/bottomNav">

        <TextView
            android:id="@+id/tvTituloRelatorioInterno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Relatório por Matéria"
            android:textColor="@color/text_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVazioRelatorio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Ainda não há dados para o relatório."
            android:textColor="@color/text_muted"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompartilharRelatorio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Compartilhar Relatório"
            android:textColor="@color/bg_white"
            app:backgroundTint="@color/coral_primary"
            app:cornerRadius="10dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_menu_flutuante"
        android:elevation="10dp"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnNavInicio"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_inicio"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnNavHistorico"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_historico"
            app:tint="@color/text_muted" />

        <ImageButton
            android:id="@+id/btnNavRelatorio"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="@drawable/bg_item_selecionado"
            android:src="@drawable/ic_nav_relatorio"
            app:tint="@color/coral_primary" />

        <ImageButton
            android:id="@+id/btnNavConfig"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_nav_config"
            app:tint="@color/text_muted" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>